# FLoRA Extractor — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Your email address — included in API request headers for OpenAlex and Crossref
# (required for polite pool access, higher rate limits)
RESEARCHER_EMAIL=you@example.com

# Gemini API key — primary LLM (free tier at aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here

# ── Optional but recommended ──────────────────────────────────────────────────

# Additional Gemini API keys for quota rotation.
# Add as many as you have — keys must be sequential (2, 3, 4, …).
# The pipeline stops loading at the first missing slot, so never leave gaps.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=
# GEMINI_API_KEY_5=
# GEMINI_API_KEY_6=  (keep adding as needed — no code changes required)

# OpenAI API key — fallback LLM (only called when Gemini fails)
OPENAI_API_KEY=

# OpenRouter API key — when set, Qwen is used as the PRIMARY LLM for original-study linking.
# Get a key at openrouter.ai — free credits available.
# Leave empty to keep Gemini as primary.
OPENROUTER_API_KEY=

# OpenRouter model for linking (default: qwen/qwen3.5-35b-a3b)
# OPENROUTER_HEAVY_MODEL=qwen/qwen3.5-35b-a3b

# ── Optional infrastructure ───────────────────────────────────────────────────

# GROBID server URL — used for reference extraction from PDFs
# Run locally: docker run -t --rm -p 8070:8070 lfoppiano/grobid:0.8.0
# Leave empty to skip GROBID (PDF reference extraction will be limited)
GROBID_URL=http://localhost:8070

# ── Model names ───────────────────────────────────────────────────────────────
# Light model: fast, cheap — used for classify_match_type and outcome extraction
# Default: gemini-2.0-flash-lite  (stable, high RPM quota)
# GEMINI_LIGHT_MODEL=gemini-2.0-flash-lite

# Heavy model: used for DOI resolution (complex linking)
# Default: same as GEMINI_MODEL
# GEMINI_HEAVY_MODEL=gemini-2.0-flash

# Main model (fallback when LIGHT/HEAVY not set)
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4o-mini

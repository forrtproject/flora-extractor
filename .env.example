# FLoRA Extractor — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Your email address — included in API request headers for OpenAlex and Crossref
# (required for polite pool access, higher rate limits)
RESEARCHER_EMAIL=you@example.com

# Gemini API key — primary LLM (free tier at aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here

# ── Optional but recommended ──────────────────────────────────────────────────

# Additional Gemini API keys for quota rotation.
# Add as many as you have — keys must be sequential (2, 3, 4, …).
# The pipeline stops loading at the first missing slot, so never leave gaps.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=
# GEMINI_API_KEY_5=
# GEMINI_API_KEY_6=  (keep adding as needed — no code changes required)

# OpenAI API key — fallback LLM (only called when Gemini fails)
OPENAI_API_KEY=

# OpenAlex API key — optional, recommended for Stage 3.
# Without it: polite pool via mailto= parameter — works fine for normal usage.
# With it: higher rate limits + authenticated access to content.openalex.org
# (the GROBID XML endpoint used by Tier 0 PDF acquisition in Stage 3).
# Get one at https://openalex.org or via your institution's OpenAlex access.
OPENALEX_API_KEY=

# Semantic Scholar API key
S2_API_KEY

# OpenRouter API key — when set, Qwen is used as the PRIMARY LLM for original-study linking.
# Get a key at openrouter.ai — free credits available.
# Leave empty to keep Gemini as primary.
OPENROUTER_API_KEY=

# OpenRouter model for linking (default: qwen/qwen3.5-35b-a3b)
# OPENROUTER_HEAVY_MODEL=qwen/qwen3.5-35b-a3b

# ── Optional infrastructure ───────────────────────────────────────────────────

# GROBID server URL — used for reference extraction from PDFs
# Run locally: docker run -t --rm -p 8070:8070 lfoppiano/grobid:0.8.0
# Leave empty to skip GROBID (PDF reference extraction will be limited)
GROBID_URL=http://localhost:8070

# ── Model names ───────────────────────────────────────────────────────────────
# Primary Gemini model — used for all LLM calls unless overridden below
# Default: gemini-3-flash-preview
# GEMINI_MODEL=gemini-3-flash-preview

# Heavy model: used for DOI resolution and match-type classification (complex reasoning)
# Default: same as GEMINI_MODEL
# GEMINI_HEAVY_MODEL=gemini-3-flash-preview

# Light model: kept for backward-compatibility; no longer used by default in extract/filter
# Default: gemini-2.5-flash-lite
# GEMINI_LIGHT_MODEL=gemini-2.5-flash-lite

# OpenAI models
# Default: gpt-5-mini
# OPENAI_MODEL=gpt-5-mini
# FILTER_OPENAI_MODEL=gpt-5-mini   # Stage 2 LLM filter (primary, before Gemini fallback)

# ── Gemini flex inference ─────────────────────────────────────────────────────
# Set to true to use flex inference on GEMINI_API_KEY (key 1).
# Requires a paid-tier key. Costs 50% less but calls may take up to 15 minutes.
# Keys 2+ are unaffected and always use standard inference.
# GEMINI_USE_FLEX=true
# GEMINI_FLEX_TIMEOUT=900   # seconds; 900 = 15 minutes (Google's stated maximum)
